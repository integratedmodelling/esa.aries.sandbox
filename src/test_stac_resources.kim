model local:alessio.bulckaen:im.data.global:ecdc__climate__summer_diurnal_air_temperature_mean__global__1981_2010 
	as im:Mean earth:AtmosphericTemperature during earth:Summer in Celsius named summer_diurnal_mean_air_temperature
	set to [self / 100];

model level of im:Mean earth:AtmosphericTemperature during earth:Summer named summer_diurnal_mean_air_temperature_level
	observing
		im:Mean earth:AtmosphericTemperature during earth:Summer in Celsius named summer_diurnal_mean_air_temperature
	lookup(summer_diurnal_mean_air_temperature, ?) into
		  summer_diurnal_mean_air_temperature	| category
		-----------------------------------------------------------------------------
				   -10 to 0						| ecology.incubation:Cold		  ,
					 0 to 10					| ecology.incubation:Cool		  ,
					10 to 18					| ecology.incubation:Mild		  ,
					18 to 22					| ecology.incubation:Warm		  ,
					22 to 28					| ecology.incubation:Hot		  ,
					28 to 35					| ecology.incubation:VeryHot	  ,
					    > 35					| ecology.incubation:ExtremelyHot ;

model local:alessio.bulckaen:im.data.global:ecdc__climate__winter_diurnal_air_temperature_mean__global__1981_2010 
	as im:Mean earth:AtmosphericTemperature during earth:Winter in Celsius named winter_diurnal_mean_air_temperature
	set to [self / 100];
	
model level of im:Mean earth:AtmosphericTemperature during earth:Winter named winter_diurnal_mean_air_temperature_level
	observing
		im:Mean earth:AtmosphericTemperature during earth:Winter in Celsius named winter_diurnal_mean_air_temperature
	lookup(winter_diurnal_mean_air_temperature, ?) into
		  winter_diurnal_mean_air_temperature	| category
		------------------------------------------------------------------------------
				 		< -25					| ecology.incubation:ExtremelyCold	,
				   -25 to -10					| ecology.incubation:VeryCold		,
				   -10 to 0						| ecology.incubation:Cold		  	,
					 0 to 10					| ecology.incubation:Cool		  	,
					10 to 18					| ecology.incubation:Mild		  	,
					18 to 22					| ecology.incubation:Warm	  		,
					22 to 28					| ecology.incubation:Hot 			;		

