model local:alessio.bulckaen:im.data.global:ecdc__climate__seasonal_diurnal_air_temperature_amplitude__global__1981_2010 
	as level of im:Daily im:Differential im:Seasonal earth:AtmosphericTemperature named seasonal_diurnal_air_temperature_amplitude_level
	lookup(self, ?) into
		seasonal_diurnal_air_temperature_amplitude  | category
	   --------------------------------------------------------
					0 to 10 						| im:Low  ,
					   > 21 						| im:High ;

model local:alessio.bulckaen:im.data.global:ecdc__climate__seasonal_diurnal_air_temperature_variability__global__1981_2010
	as im:Daily im:Changed im:Seasonal earth:AtmosphericTemperature in Celsius named seasonal_diurnal_air_temperature_variability
	set to [self * 0.1 - 273.5];
	
model level of im:Daily im:Changed im:Seasonal earth:AtmosphericTemperature named seasonal_diurnal_air_temperature_variability_level
	observing
		im:Daily im:Changed im:Seasonal earth:AtmosphericTemperature in Celsius named seasonal_diurnal_air_temperature_variability
	lookup(seasonal_diurnal_air_temperature_variability, ?) into
		   seasonal_diurnal_air_temperature_variability | category
		---------------------------------------------------------------
						  0								| im:VeryLow  ,
					 1 to 25							| im:Low	  ,
					25 to 75							| im:Moderate ,
						> 75							| im:High	  ;
	
number local:alessio.bulckaen:im.data.global:ecdc__vegetation__specific_leaf_area__global__2000_2020 as test_specific_leaf_area74;

model local:alessio.bulckaen:im.data.global:ecdc__climate__summer_diurnal_air_temperature_mean__global__1981_2010 
	as im:Mean earth:AtmosphericTemperature during earth:Summer in Celsius named summer_diurnal_mean_air_temperature
	set to [self / 100];

model level of im:Mean earth:AtmosphericTemperature during earth:Summer named summer_diurnal_mean_air_temperature_level
	observing
		im:Mean earth:AtmosphericTemperature during earth:Summer in Celsius named summer_diurnal_mean_air_temperature
	lookup(summer_diurnal_mean_air_temperature, ?) into
		  summer_diurnal_mean_air_temperature	| category
		-----------------------------------------------------------------------------
				   -10 to 0						| ecology.incubation:Cold		  ,
					 0 to 10					| ecology.incubation:Cool		  ,
					10 to 18					| ecology.incubation:Mild		  ,
					18 to 22					| ecology.incubation:Warm		  ,
					22 to 28					| ecology.incubation:Hot		  ,
					28 to 35					| ecology.incubation:VeryHot	  ,
					    > 35					| ecology.incubation:ExtremelyHot ;

model local:alessio.bulckaen:im.data.global:ecdc__climate__winter_diurnal_air_temperature_mean__global__1981_2010 
	as im:Mean earth:AtmosphericTemperature during earth:Winter in Celsius named winter_diurnal_mean_air_temperature
	set to [self / 100];
	
model level of im:Mean earth:AtmosphericTemperature during earth:Winter named winter_diurnal_mean_air_temperature_level
	observing
		im:Mean earth:AtmosphericTemperature during earth:Winter in Celsius named winter_diurnal_mean_air_temperature
	lookup(winter_diurnal_mean_air_temperature, ?) into
		  winter_diurnal_mean_air_temperature	| category
		------------------------------------------------------------------------------
				 		< -25					| ecology.incubation:ExtremelyCold	,
				   -25 to -10					| ecology.incubation:VeryCold		,
				   -10 to 0						| ecology.incubation:Cold		  	,
					 0 to 10					| ecology.incubation:Cool		  	,
					10 to 18					| ecology.incubation:Mild		  	,
					18 to 22					| ecology.incubation:Warm	  		,
					22 to 28					| ecology.incubation:Hot 			;		

model local:alessio.bulckaen:im.data.global:ecdc__climate__thermal_belts__global__1950_2000 
	as type of ecology:MountainClimaticBeltZone named thermal_belts_type
	classified into
		ecology:UpperAlpine  if 2,
		ecology:LowerAlpine  if 3,
		ecology:UpperMontane if 4,
		ecology:LowerMontane if 5,
		ecology:Lowland 	 if in (6, 7);
	
number local:alessio.bulckaen:im.data.global:ecdc__coastal__tidal_zone_intertidal__global__2017_2019 as test_tidal_zone_intertidal77;

model local:alessio.bulckaen:im.data.global:ecdc__atmosphericdisturbances__tropical_storms_exposure__global__1990_2015
	as presence of ecology:Tropical earth:Region with im:Mean im:Maximum earth:WindSpeed of earth:Storm named tropical_storms_exposure_presence
	set to [self >= 50 ? true : false]
	over space(shape="POLYGON ((180 -42, 180 66.60000000000001, -176.3 66.60000000000001, -176.3 -42, 180 -42))");
	// TODO: Need threshold to distinguish presence of tropical storm.
	
model local:alessio.bulckaen:im.data.global:ecdc__atmosphericdisturbances__coastal_storms_exposure__global__1979_2014
	as presence of earth:Coast with im:High earth:WindSpeed of earth:Storm named coastal_storms_exposure_presence
	set to [self == 1 ? true : false];

number local:alessio.bulckaen:im.data.global:ecdc__surfacewater__watershed_hierarchy__global__2004_2013 as test_watershed_hierarchy80;

number local:alessio.bulckaen:im.data.global:ecdc__surfacewater__watershed_hydroform_density__south_africa__2013_2020 as test_watershed_hydroform_density81;
number local:alessio.bulckaen:im.data.global:ecdc__surfacewater__watershed_hydroform_density__viet_nam__2013_2020 as test_watershed_hydroform_density82;
number local:alessio.bulckaen:im.data.global:ecdc__surfacewater__watershed_hydroform_density__norway__2013_2020 as test_watershed_hydroform_density83;
number local:alessio.bulckaen:im.data.global:ecdc__surfacewater__watershed_hydroform_density__greece__2013_2020 as test_watershed_hydroform_density84;
number local:alessio.bulckaen:im.data.global:ecdc__surfacewater__watershed_hydroform_density__czechia__2013_2020 as test_watershed_hydroform_density85;
number local:alessio.bulckaen:im.data.global:ecdc__surfacewater__watershed_hydroform_density__colombia__2013_2020 as test_watershed_hydroform_density86;






