//		lookup (annual_net_primary_productivity_total_input, ?) into
//		primary_productivity | category
//		--------------------------------------
//			       0 to 500  | im:Low		,
//			     500 to 2000 | im:Moderate	,
//				    >2000    | im:High		;
				    
