private namespace rule_based_modelling_czech_republic
using 
	nca.ecosystemtype.classification.czech_republic,
	nca.ecosystem.iucn,
	hydrology,
	nca.ecology;

observe earth:Region named czech_republic_krkonossky_30m_cz2  
    over space (urn = 'local:justus.muhando:esa.aries.sandbox:esa_weed_czechrepublic_priority_areas_epsg4326_v2#weed_site=CZ2',
    			grid="30 m",
                projection= "EPSG:4326"),
//        time(start=2022, end=2023, step=1.year);   
         time (year = 2024);
         
define CZECH_REPUBLIC_IUCN_GET as {{
  czech_national_ecosystem_type_classification                                               | iucn_get                                                   | wetness_regime 	| plantation | vegetation_composition 
  -------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------
  nca.ecosystemtype.classification.czech_republic:TransportNetwork                           | nca.ecosystem.iucn:UrbanIndustrialEcosystem                | #               | #          | #                     ,
