model	
'local:alessio.bulckaen:im.data.global:ecdc__vegetation__leaf_area_index__global__2024'
as ecology:LeafAreaIndex
over space(shape='POLYGON ((179.9985119064 -59.9985119047, 179.9985119064 80.0014880952, -180 80.0014880952, -180 -59.9985119047, 179.9985119064 -59.9985119047))');
