observe earth:Region named senegal_2000mt_anat_32628
     over space(urn='local:alessio.bulckaen:esa.aries.sandbox:im-nca-senegal_senegal_boundaries_anat',
	       grid= '1000 m',
	       projection='EPSG:32628'),
	      time(start=2020, end=2021, step=1.year);
model local:alessio.bulckaen:esa.aries.sandbox:im-nca-senegal.occsol_2020_anat_32628
	  as landcover:LandCoverType classified into
		landcover:IndustrialCommercialTransport if 1,
		landcover:Watercourse if 2,
		landcover:PermanentlyIrrigatedArableLand if 3,
		agriculture:Legume  landcover:ArableLand if 4,
		landcover:NonIrrigatedArableLand if 5,
		landcover:BeachDuneSand if 6,
		landcover:OpenDeciduousBroadleafForest if 7,
		landcover:StillWaterBody if 8,
		landcover:Urban if 9,
		landcover:Mangrove if 10,
		hydrology:Seasonal  landcover:WaterBody if 11,
		landcover:InlandWetland if 12,
		landcover:PermanentCropland if 13,
		landcover:VegetatedStillWaterBody if 14,
		landcover:ClosedSavanna if 15,
		landcover:OpenSavanna if 16,
		landcover:SparseVegetation if 17,
		landcover:BareArea if 18,
		landcover:IntertidalFlat if in (19 20);	