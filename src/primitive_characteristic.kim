project private namespace primitive_characteristic;

//TODO:Add proper concepts
identity Variability;
//identity Size; //for area of leaf

observe earth:Region named greece_test_area_2018
over space(shape=
//"EPSG:4326 POLYGON((30.295365 34.8, 30.295365 42.396401, 19.261895 42.396401, 19.261895 34.8, 30.295365 34.8))"
"EPSG:4326 POLYGON ((22.335579997340485 37.505486618136544, 22.13570513274892 37.505486618136544, 22.13570513274892 37.57798257227124, 22.335579997340485 37.57798257227124, 22.335579997340485 37.505486618136544))
",
		   grid="100 m"),
time(start=2018, end=2019, step=1.year);
  
// 1. Proposed annotation for peat_thickness
// Description: Vertical depth of the accumulated peat layer.
// Concept: im:Depth applied to a PeatBog context. 
// Note: 'landcover:PeatBog' is defined in the landcover namespace [576].
//model 'local:alessio.bulckaen:im.data.global:ecdc__soil__peat_thickness__global__2001_2021' 
//  as im:Depth of landcover:PeatBog earth:Region 
//  in cm;

  
/*Refined annotation for ECDC primitive characteristics*/
//1. Proposed annotation for peat_thickness
model
'local:alessio.bulckaen:im.data.global:ecdc__soil__peat_thickness__global__2001_2021'
as im:Depth of landcover:PeatBog earth:Region in cm;
//over space(shape='POLYGON ((180 -60.007460979, 180 88.007948385, -180 88.007948385, -180 -60.007460979, 180 -60.007460979))');

//1B. Proposed annotation for physical_properties_bulk_density
model 
'local:alessio.bulckaen:im.data.global:ecdc__soil__physical_properties_bulk_density__global__1995_2019'
as ratio of earth:Dry soil:Soil im:Mass to soil:Soil im:Volume in g/cm^3;
//2. Proposed annotation for fertility
model   
'local:alessio.bulckaen:im.data.global:ecdc__soil__fertility__global__2001_2020'
as level of soil.incubation:SoilFertility classified into
  	soil.incubation:Infertile if in (0 1 2),
	soil.incubation:LowFertility if in (3 4),
	soil.incubation:MediumFertility if in (5 6 7),
	soil.incubation:HighFertility if in (8 9 10)
over space(shape="POLYGON ((180 -90, 180 90, -180 90, -180 -90, 180 -90))");
//	soil.incubation:SteepTerrainSlope if (11),
 
//3. Proposed annotation for nitrogen
model
//'local:alessio.bulckaen:im.data.global:ecdc__soil__nitrogen__global__1995_2019'
'local:alessio.bulckaen:im.data.global:ecdc__soil__chemical_properties_n__global__1995_2019'
as proportion of chemistry:Nitrogen in soil:Soil //  in g/kg;
over space(shape='POLYGON ((180 -90, 180 90, -180 90, -180 -90, 180 -90))');
//4. Proposed annotation for base_saturation
model
//'local:alessio.bulckaen:im.data.global:ecdc__soil__base_saturation__global__1995_2019'
'local:alessio.bulckaen:im.data.global:ecdc__soil__chemical_properties_base_saturation__global__1995_2019'
as percentage of (chemistry:Basic chemistry:ExchangeCapacity) in (chemistry:ExchangeCapacity of chemistry:Cation)
over space(shape='POLYGON ((180 -90, 180 90, -180 90, -180 -90, 180 -90))');
//5. Proposed annotation for tropical_storms_exposure
model
'local:alessio.bulckaen:im.data.global:ecdc__atmosphericdisturbances__tropical_storms_exposure__global__1990_2015'
as im:Mean im:Maximum earth:WindSpeed of earth:Storm in km/h //knot 
over space(shape='POLYGON ((180 -42, 180 66.6, -176.3 66.6, -176.3 -42, 180 -42))');

model 'local:alessio.bulckaen:im.data.global:ecdc__atmosphericdisturbances__tropical_storms_exposure__global__1990_2015'
 as presence of ecology:Tropical earth:Storm
  set to [self > 0 ];
 
number 'local:alessio.bulckaen:im.data.global:ecdc__atmosphericdisturbances__tropical_storms_exposure__global__1990_2015' as tropical_storm_data_test;
   
//6. Proposed annotation for tidal_zone_intertidal
model
'local:alessio.bulckaen:im.data.global:ecdc__coastal__tidal_zone_intertidal__global__2017_2019'
as presence of earth:Wetland by earth:Coast
//over space(shape='POLYGON ((180 -60.0000049623, 180 60, -180 60, -180 -60, 180 -60))')
set to [self == 1 ? true : false];

number 'local:alessio.bulckaen:im.data.global:ecdc__coastal__tidal_zone_intertidal__global__2017_2019' as tidal_zone_intertidal;


//7. Proposed annotation for annual_total_net_primary_productivity
@intensive(space)   
model
'local:alessio.bulckaen:im.data.global:ecdc__ecosystemfunction__annual_net_primary_productivity_total__global__2018',
'local:alessio.bulckaen:im.data.global:ecdc__ecosystemfunction__annual_net_primary_productivity_total__global__2021',
'local:alessio.bulckaen:im.data.global:ecdc__ecosystemfunction__annual_net_primary_productivity_total__global__2024'
as ecology:NetPrimaryProduction in g/m^2       
over space(shape='POLYGON ((180 -60, 180 80, -180 80, -180 -60, 180 -60))');
//over space(shape='POLYGON ((179.9985147848 -59.9985130248, 179.9985147848 80.0014880952, -180 80.0014880952, -180 -59.9985130248, 179.9985147848 -59.9985130248))');

////7B. Proposed annotation for annual_total_net_primary_productivity
//@intensive(space)
//model
//'local:alessio.bulckaen:esa.aries.sandbox:testing.geometry:STAC'
//as ecology:NetPrimaryProduction in g/m^2
//over space(shape='POLYGON ((179.9985147848 -59.9985130248, 179.9985147848 80.0014880952, -180 80.0014880952, -180 -59.9985130248, 179.9985147848 -59.9985130248))');

//8. Proposed annotation for floodplain
model
'local:alessio.bulckaen:im.data.global:ecdc__geomorphology__floodplain__global__1900_2100'
as presence of hydrology:Floodplain
over space(shape='POLYGON ((180 -90, 180 90, -180 90, -180 -90, 180 -90))')
set to [self == 0 ? true : false];

//9. Proposed annotation for geothermal
model
'local:alessio.bulckaen:im.data.global:ecdc__energy__geothermal__global__2019'
as earth:Crust physical:Thermal im:Energy in mW/m^2
over space(shape='POLYGON ((180 -90, 180 90, -180 90, -180 -90, 180 -90))');
//10. Proposed annotation for recurrence
model
'local:alessio.bulckaen:im.data.global:ecdc__wildfiredisturbances__recurrence__global__2002_2024'
as count of im:Yearly im:Occurrence of chemistry:Fire in year
over space(shape='POLYGON ((180 -60.0003350977, 180 69.9999999937, -180 69.9999999937, -180 -60.0003350977, 180 -60.0003350977))');
//11. Proposed annotation for periodicity
model
'local:alessio.bulckaen:im.data.global:ecdc__wildfiredisturbances__periodicity__global__2002_2024'
as presence of im:Regular chemistry:Fire
over space(shape='POLYGON ((180 -60.0003350977, 180 69.9999999937, -180 69.9999999937, -180 -60.0003350977, 180 -60.0003350977))');
//12. Proposed annotation for biotic_assemblage_pinniped_colonies
model
'local:alessio.bulckaen:im.data.global:ecdc__bioticassemblages__biotic_assemblage_pinniped_colonies__global__2022'
as presence of GBIF.SPECIES:4941589 ecology:Population
over space(shape='POLYGON ((180 -90, 180 90, -180 90, -180 -90, 180 -90))');
