project private namespace primitive_characteristic;

number local:alessio.bulckaen:im.data.global:copernicus_global_dynamic_landcover_10m_2020 as lc_test;

model local:alessio.bulckaen:im.data.global:copernicus_global_dynamic_landcover_10m_2020
	as landcover:LandCoverType named copernicus_gdlc_2020 classified into // according to im:copernicus-gdlc-encoding;// im:copernicus-encoding;
	landcover:Forest if 10,
	landcover:Shrubland if 20,
	landcover:Grassland if 30,
	landcover:AgriculturalVegetation if 40,
	landcover:ArtificialSurface if 50,
	landcover:SparseVegetation if 60,
	landcover:GlacierPerpetualSnow if 70,
	landcover:WaterBody if 80,
	landcover:AquaticVegetationOverWaterBody if 90, //Should be HerbaceusWetland, so including both InlandMarsh&SaltMarsh, but that's inconsistent with our current structure
	landcover:Mangrove if 95,
	landcover:LichenMoss if 100;
 
//model local:alessio.bulckaen:im.data.global:im-data-global-ecology.global_globmapftc_fractional_tree_cover_epsg4326_250m_2020
//as 	presence of ecology:Tree
//set to [self == unknown ? false : true];

//model local:rubencc:im.data.global:im-data-global-landcover.cci_lc_300m_2020_v2_1_1,
//	  local:rubencc:im.data.global:im-data-global-landcover.cci_lc_300m_2021,
//	  local:rubencc:im.data.global:im-data-global-landcover.cci_lc_300m_2022
//	as type of ecology:LeafPhenology named phenology classified into
//		ecology:MixedLeafPhenology if in (40 90 100 120),  
//		ecology:Deciduous if in (60 61 62 122), 
//	  	ecology:Evergreen if in (50 70 71 72 121);

//annotation of summer_diurnal_air_temperature_mean thresholds
//model 'local:alessio.bulckaen:im.data.global:ecdc__climate__summer_diurnal_air_temperature_mean__global__1981_2010'
// as level of im:Mean earth:AtmosphericTemperature during earth:Summer named summer_diurnal_air_temperature_mean
//	lookup(summer_diurnal_air_temperature_mean) into
//	summer_diurnal_air_temperature_mean | category
//	----------------------------------------------
//	-10 to 0  | ecology.incubation:Cold,
//	  0 to 10 | ecology.incubation:Cool,
//	 10 to 18 | ecology.incubation:Mild,
//	 18 to 22 | ecology.incubation:Warm,
//	 22 to 28 | ecology.incubation:Hot,
//	 28 to 35 | ecology.incubation:VeryHot,
//	   >=35   | ecology.incubation:ExtremelyHot
//	over space(shape="POLYGON ((180 -90, 180 90, -180 90, -180 -90, 180 -90))");

 
//annotation of annual_net_primary_productivity
model 
'local:alessio.bulckaen:im.data.global:ecdc__ecosystemfunction__annual_net_primary_productivity_total__global__2024',
'local:alessio.bulckaen:im.data.global:ecdc__ecosystemfunction__annual_net_primary_productivity_total__global__2021',
'local:alessio.bulckaen:im.data.global:ecdc__ecosystemfunction__annual_net_primary_productivity_total__global__2018'
as ecology:NetPrimaryProduction named annual_net_primary_productivity
	classified into
	im:Low if in (0 to 500),
	im:Moderate if in (500 to 2000),
	im:High if >=2000;
//over space(shape='POLYGON ((180 -60, 180 60, -180 60, -180 -60, 180 -60))'); 

