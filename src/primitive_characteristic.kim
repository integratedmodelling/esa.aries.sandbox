'local:alessio.bulckaen:im.data.global:ecdc__vegetation__specific_leaf_area__global__2000_2020'
as ratio of  im:Area to im:Mass of biology:Leaf in m^2/kg  
over space(shape='POLYGON ((180 -90, 180 90, -180 90, -180 -90, 180 -90))');
//110. Proposed annotation for leaf_size  
model
'local:alessio.bulckaen:im.data.global:ecdc__vegetation__leaf_size__global__2000_2020'
as im:Area of biology:Leaf in mm^2      
over space(shape='POLYGON ((180 -90, 180 90, -180 90, -180 -90, 180 -90))');

