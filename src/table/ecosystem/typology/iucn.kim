private namespace table.ecosystem.typology.iucn
using nca.ecosystem.iucn;

define BIOME_F1_RIVERSTREAM_ECOSYSTEM_TYPES as {{
  hydroform           | hydroperiod       	| watershed_hierarchy | ecosystem_type                           
  ----------------------------------------------------------------------------------------------------------------------------------------------------------------------
   hydrology:WaterBody| hydrology:Permanent  | im:Low              | nca.ecosystem.iucn:PermanentUplandStream  ,
   hydrology:Meander  | #                    | im:Moderate         | nca.ecosystem.iucn:PermanentLowlandStream ,
   hydrology:WaterBody|#                    | #                   | nca.ecosystem.iucn:FreezethawRiverStream  ,
   hydrology:WaterBody| hydrology:Seasonal   | im:Low              | nca.ecosystem.iucn:SeasonalUplandStream   ,
   hydrology:WaterBody|hydrology:Seasonal   | im:Moderate         | nca.ecosystem.iucn:SeasonalLowlandRiver   ,
   hydrology:WaterBody|hydrology:Episodic   | #                   | nca.ecosystem.iucn:EpisodicAridRiver      ,
   hydrology:Meander  | hydrology:Permanent  | im:High             | nca.ecosystem.iucn:LargeLowlandRiver     
}};

