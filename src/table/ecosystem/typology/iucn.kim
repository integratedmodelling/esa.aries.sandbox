  in (landcover:Forest landcover:Shrubland landcover:BareArea)                      | #                        | in (ecology.incubation:Cool ecology.incubation:Mild) | #                          | #                              | in (im:Low im:Moderate)                      | in (ecology:LowerMontane ecology:UpperMontane) | #                            | im:Moderate                           | #                                   | ecology:Dense                   | im:Moderate   | #                        | in (ecology:Microphyll ecology:Notophyll)                   | ecology:Evergreen                                 | #                              | nca.ecosystem.iucn:TropicalSubtropicalMontaneRainforest ,
  in (landcover:Forest landcover:Shrubland landcover:LichenMoss landcover:BareArea) | #                        | #                                                    | in (im:High im:VeryHigh)   | in (im:ModeratelyHigh im:High) | #                                            | #                                              | #                            | im:Low                                | im:Low                              | in (ecology:Open ecology:Dense) | im:Moderate   | in (im:Moderate im:High) | #                                                           | ecology:Evergreen                                 | #                              | nca.ecosystem.iucn:TropicalHeathForest                 
