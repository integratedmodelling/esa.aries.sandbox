  in (landcover:Shrubland landcover:Grassland landcover:LichenMoss landcover:BareArea landcover:WaterBody) | #                                                                                         | #                          | #                              | #                                            | #                                                    | #                                            | in (ecology.incubation:ExtremelyCold ecology.incubation:VeryCold) | #                                     | in (ecology:Absence ecology:VerySparse) | #                                   | #                      | soil:Deep      | in (im:VeryLow im:Low) | #                            | #                               | nca.ecosystem.iucn:PolarTundraDesert                    ,
  in (landcover:Shrubland landcover:Grassland landcover:LichenMoss landcover:BareArea)                     | #                                                                                         | #                          | #                              | #                                            | ecology.incubation:Mild                              | in (ecology:LowerAlpine ecology:UpperAlpine) | #                                                                 | in (im:Low im:Moderate)               | #                                       | #                                   | #                      | #              | in (im:VeryLow im:Low) | #                            | #                               | nca.ecosystem.iucn:TemperateAlpineGrasslandShrubland    ,
  in (landcover:Shrubland landcover:Grassland landcover:LichenMoss landcover:BareArea)                     | in (ecology.incubation:ExtremelyCold ecology.incubation:VeryCold ecology.incubation:Cold) | #                          | in (im:ModeratelyHigh im:High) | in (im:VeryLow im:Low)                       | #                                                    | in (ecology:LowerAlpine ecology:UpperAlpine) | #                                                                 | im:Low                                | #                                       | #                                   | #                      | #              | im:VeryLow             | in (im:Low im:ModeratelyLow) | ecology.incubation:MultiDecadal | nca.ecosystem.iucn:TropicalAlpineGrasslandShrubland    
}};

