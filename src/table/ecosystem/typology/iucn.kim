private namespace table.ecosystem.typology.iucn
using nca.ecosystem.iucn;

define BIOME_F1_RIVER_STREAM_ECOSYSTEM_TYPES_SHORT_TABLE as {{
  hydroform           | hydroperiod       	| watershed_hierarchy | ecosystem_type                           
  ----------------------------------------------------------------------------------------------------------------------------------------------------------------------
   hydrology:WaterBody| hydrology:Permanent  | im:Low              | nca.ecosystem.iucn:PermanentUplandStream  ,
   hydrology:Meander  | #                    | im:Moderate         | nca.ecosystem.iucn:PermanentLowlandStream ,
   hydrology:WaterBody| #                    | #                   | nca.ecosystem.iucn:FreezethawRiverStream  ,
   hydrology:WaterBody| hydrology:Seasonal   | im:Low              | nca.ecosystem.iucn:SeasonalUplandStream   ,
   hydrology:WaterBody| hydrology:Seasonal   | im:Moderate         | nca.ecosystem.iucn:SeasonalLowlandRiver   ,
   hydrology:WaterBody| hydrology:Episodic   | #                   | nca.ecosystem.iucn:EpisodicAridRiver      ,
   hydrology:Meander  | hydrology:Permanent  | im:High             | nca.ecosystem.iucn:LargeLowlandRiver     
}};

define BIOME_F1_RIVER_STREAM_ECOSYSTEM_TYPES as {{
  waterbody_type        | water_permanence    | watershed_hierarchy | ecosystem_type                           
  -------------------------------------------------------------------------------------------------------------
  hydrology:Watercourse | hydrology:Permanent | im:Low              | nca.ecosystem.iucn:PermanentUplandStream  ,
  hydrology:Watercourse | hydrology:Permanent | im:Moderate         | nca.ecosystem.iucn:PermanentLowlandStream ,
  hydrology:Meander     | hydrology:Permanent | im:Moderate         | nca.ecosystem.iucn:PermanentLowlandStream ,
  hydrology:Watercourse | #                   | #                   | nca.ecosystem.iucn:FreezethawRiverStream  ,
  hydrology:Watercourse | hydrology:Seasonal  | im:Low              | nca.ecosystem.iucn:SeasonalUplandStream   ,
  hydrology:Watercourse | hydrology:Seasonal  | im:Moderate         | nca.ecosystem.iucn:SeasonalLowlandRiver   ,
  hydrology:Watercourse | hydrology:Episodic  | #                   | nca.ecosystem.iucn:EpisodicAridRiver      ,
  hydrology:Watercourse | hydrology:Permanent | im:High             | nca.ecosystem.iucn:LargeLowlandRiver      ,
  hydrology:Meander     | hydrology:Permanent | im:High             | nca.ecosystem.iucn:LargeLowlandRiver     
}};

define BIOME_F2_LAKE_ECOSYSTEM_TYPES as {{
  landcover                                  | geothermal | chemical_properties_base_saturation | hydroform                 | hydroform_morphology_area | hydroperiod         | ecosystem_type                                 
  -----------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------
  landcover:WaterBody                        | #          | #                                   | hydrology:InlandWaterBody | im:High                   | hydrology:Permanent | nca.ecosystem.iucn:LargePermanentFreshwaterLake ,
  #                                          | true       | #                                   | #                         | #                         | #                   | nca.ecosystem.iucn:SubglacialLake               ,
  landcover:WaterBody                        | #          | #                                   | hydrology:InlandWaterBody | im:Low                    | hydrology:Permanent | nca.ecosystem.iucn:SmallPermanentFreshwaterLake ,
  #                                          | #          | #                                   | hydrology:InlandWaterBody | #                         | hydrology:Seasonal  | nca.ecosystem.iucn:SeasonalFreshwaterLake       ,
  landcover:WaterBody                        | #          | #                                   | hydrology:InlandWaterBody | #                         | #                   | nca.ecosystem.iucn:FreezethawFreshwaterLake     ,
  #                                          | #          | #                                   | hydrology:InlandWaterBody | #                         | hydrology:Ephemeral | nca.ecosystem.iucn:EphemeralFreshwaterLake      ,
  landcover:WaterBody                        | #          | #                                   | hydrology:InlandWaterBody | #                         | hydrology:Permanent | nca.ecosystem.iucn:PermanentSaltSodaLake        ,
  #                                          | #          | #                                   | hydrology:InlandWaterBody | #                         | hydrology:Ephemeral | nca.ecosystem.iucn:EphemeralSaltLake            ,
  in (landcover:WaterBody landcover:Wetland) | #          | in (im:Moderate im:High)            | hydrology:InlandWaterBody | #                         | hydrology:Permanent | nca.ecosystem.iucn:ArtesianSpringOase           ,
  in (landcover:WaterBody landcover:Wetland) | true       | #                                   | hydrology:InlandWaterBody | #                         | hydrology:Permanent | nca.ecosystem.iucn:GeothermalPoolWetland       
}};


define BIOME_F3_ARTIFICIAL_WETLAND_ECOSYSTEM_TYPES as {{
  landcover                                                                | managed_waterbody_type         | waterbody_type            | water_permanence                             | ecosystem_type                                 
  --------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------
  landcover:WaterBody                                                      | hydrology.incubation:Reservoir | hydrology:Watercourse     | #                                            | nca.ecosystem.iucn:LargeReservoir               ,
  in (landcover:BareArea, landcover:WaterBody, landcover:Wetland)          | #                              | hydrology:InlandWaterBody | #                                            | nca.ecosystem.iucn:ConstructedLacustrineWetland ,
  in (landcover:WaterBody, landcover:Wetland)                              | #                              | #                         | in (hydrology:Seasonal, hydrology:Permanent) | nca.ecosystem.iucn:RicePaddy                    ,
  in (landcover:WaterBody, landcover:Wetland, landcover:ArtificialSurface) | #                              | hydrology:InlandWaterBody | hydrology:Permanent                          | nca.ecosystem.iucn:FreshwaterAquafarm           ,
  in (landcover:WaterBody, landcover:ArtificialSurface)                    | hydrology.incubation:Canal     | hydrology:Watercourse     | #                                            | nca.ecosystem.iucn:CanalDitchDrain             
}};

