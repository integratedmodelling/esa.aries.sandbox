private namespace primitive_characteristic.biome_intensivelandusesystem
	using nca.ecosystem.iucn;
	
define BIOME_T7_INTENSIVE_LAND_USE_SYSTEM_ECOSYSTEM_TYPES as {{
  landcover                                                                           | mining_areas | annual_water_budget_total       | annual_net_primary_productivity_total | tree_density                     | chemical_properties_base_saturation | fertility                | ecosystem_type                                      
  ---------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------
  in (landcover:Shrubland, landcover:Grassland, landcover:BareArea)                   | #            | #                               | im:High                               | im:None                          | #                                   | in (im:Low, im:Moderate) | nca.ecosystem.iucn:AnnualCropland                    ,
  in (landcover:Grassland, landcover:BareArea)                                        | true         | in (im:ModeratelyHigh, im:High) | #                                     | #                                | in (im:Moderate, im:High)           | im:Moderate              | nca.ecosystem.iucn:SownPastureField                  ,
  in (landcover:BareArea, landcover:ArtificialSurface)                                | true         | #                               | #                                     | #                                | #                                   | #                        | nca.ecosystem.iucn:UrbanIndustrialEcosystem          ,
  in (landcover:Forest, landcover:Shrubland, landcover:Grassland, landcover:BareArea) | #            | #                               | #                                     | in (im:None, ecology:VerySparse) | #                                   | #                        | nca.ecosystem.iucn:DerivedSeminaturalPastureOldfield
}};
 
//--- BIOME T7 - IntensiveLandUseSystem annotation---
model nca.ecosystem.iucn:IntensiveLandUseSystem type of nca.ecosystem.iucn:Ecosystem named biome_t7_intensive_land_use_system
	observing
		landcover:LandCoverType named landcover,
		presence of landcover:MineralExtraction earth:Region named mining_areas,
		level of (im:Yearly hydrology:WaterVolume caused by hydrology:WaterBalance) named annual_water_budget_total,
		level of ecology:NetPrimaryProduction named annual_net_primary_productivity_total,
		level of ecology:WoodyVegetation ecology:CanopyCover named tree_density,
		level of (chemistry:Basic chemistry:ExchangeCapacity of chemistry:Cation) named chemical_properties_base_saturation,
		level of soil.incubation:Fertility named fertility
		lookup (landcover, mining_areas, annual_water_budget_total, annual_net_primary_productivity_total, tree_density, chemical_properties_base_saturation, fertility, ?)
	into BIOME_T7_INTENSIVE_LAND_USE_SYSTEM_ECOSYSTEM_TYPES;

