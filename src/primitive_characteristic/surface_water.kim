/* ----------------------------------------------------------------------------------------------------------------------------- 
 * # 6) Brackish Waterbodies
 */

 model 
 'local:samjinoj:im.data.global:im-data-global-hydrology:global_wetlands_20m_2020_mosaic',
 'local:samjinoj:im.data.global:im-data-global-hydrology:global_wetlands_20m_2021_mosaic',
 'local:samjinoj:im.data.global:im-data-global-hydrology:global_wetlands_20m_2022_mosaic'
	as presence of ecology:Brackish earth:WaterBody
	set to [self==255]; 