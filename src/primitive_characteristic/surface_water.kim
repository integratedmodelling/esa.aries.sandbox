////local:alessio.bulckaen:im.data.global:ecdc__surfacewater__hydroform_morphology_area__viet_nam__2013_2020
//	as level of (im:Minimum im:Area of earth:WaterBody) named hydroform_morphology_area
//		lookup (self,?) into
//		hydroform_morphology_area | category
//		------------------------------------
//		 					 <100 | im:Low,
//							 >=100 | im:High
//	over space(shape='POLYGON ((-180 -55.87, -180 84.01, 180 84.01, 180 -55.87, -180 -55.87))');
//@intensive(space)                        
//model level of (im:Minimum im:Area of earth:WaterBody) named hydroform_morphology_area
//observing im:Minimum im:Area of earth:WaterBody in km^2
//		lookup (hydroform_morphology_area) into
//		hydroform_morphology_area | category
//		------------------------------------
//							< 100 | im:Low,
//	                        > 100 | im:High; 
	

//secondary_observation  of level of (im:Minimum im:Area of earth:WaterBody)
@intensive(space) 
model local:alessio.bulckaen:im.data.global:ecdc__surfacewater__hydroform_morphology_area__greece__2013_2020
//	  local:alessio.bulckaen:im.data.global:ecdc__surfacewater__hydroform_morphology_area__colombia__2013_2020,
//	  local:alessio.bulckaen:im.data.global:ecdc__surfacewater__hydroform_morphology_area__czechia__2013_2020,	  
//	  local:alessio.bulckaen:im.data.global:ecdc__surfacewater__hydroform_morphology_area__norway__2013_2020,
//	  local:alessio.bulckaen:im.data.global:ecdc__surfacewater__hydroform_morphology_area__south_africa__2013_2020,
//	  local:alessio.bulckaen:im.data.global:ecdc__surfacewater__hydroform_morphology_area__viet_nam__2013_2020
	as im:Minimum im:Area of earth:WaterBody in km^2 named hydroform_morphology_area_input;

//primary_observation of level of (im:Minimum im:Area of earth:WaterBody)
model level of (im:Minimum im:Area of earth:WaterBody) named hydroform_morphology_area
	observing
		im:Minimum im:Area of earth:WaterBody in km^2 named hydroform_morphology_area_input
	lookup (hydroform_morphology_area_input, ?) into
		  hydroform_morphology_area	|	category
		------------------------------------------
					<  100			|	im:Low	,
					>= 100			|	im:High
	over space(shape='POLYGON ((-180 -55.87, -180 84.01, 180 84.01, 180 -55.87, -180 -55.87))');
	
/* ----------------------------------------------------------------------------------------------------------------------------- 
 * # 5) Watershed hydroform density.
 */

model local:alessio.bulckaen:im.data.global:ecdc__surfacewater__watershed_hydroform_density__greece__2013_2020
	as level of (im:Density of earth:WaterBody) named watershed_hydroform_density
		lookup (self, ?) into
		  watershed_hydroform_density	|	category
		--------------------------------------------------
						 < 0.1			|	im:Low		,
					0.1 to 25			|	im:Moderate	,
						 > 25			|	im:High							
	over space(shape='POLYGON ((-180 -55.87, -180 84.01, 180 84.01, 180 -55.87, -180 -55.87))');

