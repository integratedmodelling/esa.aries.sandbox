private namespace primitive_characteristic.biome_desertsemidesert
	using nca.ecosystem.iucn,
	primitive_characteristic.climate;

define BIOME_T5_DESERT_SEMIDESERT_ECOSYSTEM_TYPES as {{
  landcover                                                                           | annual_diurnal_air_temperature_mean                                                      | annual_precipitation_total | annual_water_budget_total     | seasonal_diurnal_air_temperature_variability | summer_diurnal_air_temperature_mean                   | winter_diurnal_air_temperature_mean                                                         | winter_water_budget_total       | annual_net_primary_productivity_total | chemical_properties_base_saturation | chemical_properties_n | fertility                | canopy_height                    | phenology | specific_leaf_area                       | periodicity | recurrence                                                                                      | ecosystem_type                                   
  ---------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------
  #	                                                                                  | #                                                                                        | in (im:VeryLow, im:Low)    | in (im:Low, im:ModeratelyLow) | im:High                                      | #                                                     | #                                                                                           | #                               | #                                     | #                                   | #                     | in (im:Low, im:Moderate) | im:VeryLow                       | #         | in (im:ModeratelyLow, im:ModeratelyHigh) | #           | #                                                                                               | nca.ecosystem.iucn:SemidesertSteppe               ,
  in (landcover:Forest, landcover:Shrubland, landcover:Grassland, landcover:BareArea) | in (ecology.incubation:Hot, ecology.incubation:VeryHot, ecology.incubation:ExtremelyHot) | #                          | in (im:Low, im:ModeratelyLow) | in (im:VeryLow, im:Low)                      | ecology.incubation:VeryHot                            | ecology.incubation:Mild                                                                     | #                               | im:Low                                | #                                   | #                     | in (im:Low, im:Moderate) | #                                | #      	 | in (im:Low, im:ModeratelyLow)            | true        | #                                                                                               | nca.ecosystem.iucn:ThornyDesertSemidesert         ,
  in (landcover:Forest, landcover:Shrubland, landcover:Grassland, landcover:BareArea) | #                                                                                        | #                          | in (im:Low, im:ModeratelyLow) | in (im:High, im:Moderate)                    | #                                                     | #                                                                                           | #                               | #                                     | in (im:Moderate, im:High)           | im:VeryLow            | #                        | in (im:VeryLow, im:Low)          | #         | in (im:Low, im:ModeratelyLow)            | true        | in (ecology.incubation:Decadal, ecology.incubation:MultiDecadal, ecology.incubation:Centennial) | nca.ecosystem.iucn:SclerophyllHotDesertSemidesert ,
  in (landcover:Forest, landcover:Shrubland, landcover:Grassland, landcover:BareArea) | #                                                                                        | in (im:VeryLow, im:Low)    | in (im:Low, im:ModeratelyLow) | #                                            | in (ecology.incubation:Mild, ecology.incubation:Warm) | in (ecology.incubation:ExtremelyCold, ecology.incubation:VeryCold, ecology.incubation:Cold) | in (im:ModeratelyHigh, im:High) | #                                     | #                                   | #                     | #                        | in (im:None, im:VeryLow, im:Low) | #	     | #                                        | #           | #                                                                                               | nca.ecosystem.iucn:CoolDesertSemidesert           ,
  in (landcover:Forest, landcover:Shrubland, landcover:Grassland, landcover:BareArea) | #                                                                                        | im:VeryLow                 | in (im:Low, im:ModeratelyLow) | #                                            | #                                                     | #                                                                                           | #                               | im:Low                                | #                                   | #                     | #                        | #                                | #         | #                                        | #           | #                                                                                               | nca.ecosystem.iucn:HyperaridDesert               
}};


//--- BIOME T5 - DesertSemidesert annotation---
model nca.ecosystem.iucn:DesertSemidesert type of nca.ecosystem.iucn:Ecosystem named biome_t5_desert_semidesert
	observing
		landcover:LandCoverType named landcover,
		level of im:Daily im:Mean earth:AtmosphericTemperature during im:Year named annual_diurnal_air_temperature_mean,
		level of im:Yearly earth:PrecipitationVolume named annual_precipitation_total,
		level of (im:Yearly hydrology:WaterVolume caused by hydrology:WaterBalance) named annual_water_budget_total,
		level of im:Mean im:Changed primitive_characteristic.climate:SeasonalAmplitude earth:AtmosphericTemperature named seasonal_diurnal_air_temperature_variability,
		level of im:Mean earth:AtmosphericTemperature during earth:Summer named summer_diurnal_air_temperature_mean,
		level of im:Mean earth:AtmosphericTemperature during earth:Winter named winter_diurnal_air_temperature_mean,
		level of (hydrology:WaterVolume caused by hydrology:WaterBalance during earth:Winter) named winter_water_budget_total,
		level of ecology:NetPrimaryProduction named annual_net_primary_productivity_total,
		level of (chemistry:Basic chemistry:ExchangeCapacity of chemistry:Cation) named chemical_properties_base_saturation,
		level of (proportion of chemistry:Nitrogen in soil:Soil) named chemical_properties_n,
		level of soil.incubation:Fertility named fertility,
		level of (im:Mean im:Height of ecology:Canopy) named canopy_height,
		type of ecology:LeafPhenology named phenology,
		level of (ratio of im:Area to earth:Dry im:Mass of biology:Leaf) named specific_leaf_area,
		presence of earth:Region with im:High im:Frequency of chemistry:Fire named periodicity,
		level of (count of im:Yearly im:Occurrence of chemistry:Fire) named recurrence
	lookup (landcover, annual_diurnal_air_temperature_mean, annual_precipitation_total, annual_water_budget_total, seasonal_diurnal_air_temperature_variability, summer_diurnal_air_temperature_mean, winter_diurnal_air_temperature_mean, winter_water_budget_total, annual_net_primary_productivity_total, chemical_properties_base_saturation, chemical_properties_n, fertility, canopy_height, phenology, specific_leaf_area, periodicity, recurrence, ?)
	into BIOME_T5_DESERT_SEMIDESERT_ECOSYSTEM_TYPES;





























