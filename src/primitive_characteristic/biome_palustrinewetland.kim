private namespace primitive_characteristic.biome_palustrinewetland
	using   nca.ecosystem.iucn,
			primitive_characteristic.climate;

define BIOME_TF1_PALUSTRINE_WETLAND_ECOSYSTEM_TYPES as {{
  landcover                                                                                              | annual_precipitation_total | annual_water_budget_total       | seasonal_diurnal_air_temperature_variability | thermal_belts   | winter_diurnal_air_temperature_mean                                           | annual_net_primary_productivity_total | floodplain | tree_density                                     | chemical_properties_base_saturation | chemical_properties_n | peat_thickness            | waterbody_type            | water_permanence    | canopy_cover                     | canopy_height                                      | leaf_area_index           | leaf_size                                 | phenology         | specific_leaf_area                       | periodicity | ecosystem_type                                            
  ------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------
  in (landcover:Forest, landcover:Shrubland, landcover:Grassland, landcover:Wetland)                     | in (im:High, im:VeryHigh)  | #                               | in (im:VeryLow, im:Low)                      | #               | in (ecology.incubation:Mild, ecology.incubation:Warm, ecology.incubation:Hot) | #                                     | true       | #                                                | #                                   | #                     | im:High                   | #                         | #                   | ecology:Dense                    | #                                                  | in (im:High, im:VeryHigh) | in (ecology:Notophyll, ecology:Mesophyll) | ecology:Evergreen | in (im:ModeratelyLow, im:ModeratelyHigh) | #           | nca.ecosystem.iucn:TropicalFloodedForestPeatForest         ,
  in (landcover:Forest, landcover:Shrubland, landcover:Grassland, landcover:BareArea, landcover:Wetland) | #                          | #                               | #                                            | ecology:Lowland | #                                                                             | #                                     | #          | #                                                | #                                   | #                     | #                         | hydrology:Watercourse     | #                   | in (ecology:Open, ecology:Dense) | in (im:Low, im:Moderate, im:High)                  | #                         | #                                         | #                 | #                                        | false       | nca.ecosystem.iucn:SubtropicalWarmTemperateForestedWetland ,
  in (landcover:Shrubland, landcover:Grassland, landcover:BareArea, landcover:Wetland)                   | #                          | #                               | #                                            | #               | #                                                                             | im:High                               | true       | im:None                                          | #                                   | #                     | #                         | hydrology:InlandWaterBody | hydrology:Permanent | #                                | #                                                  | #                         | #                                         | #                 | #                                        | #           | nca.ecosystem.iucn:PermanentMarsh                          ,
  in (landcover:Shrubland, landcover:Grassland, landcover:BareArea, landcover:Wetland)                   | #                          | #                               | #                                            | #               | #                                                                             | im:High                               | true       | #                                                | #                                   | #                     | #                         | #                         | hydrology:Seasonal  | #                                | #                                                  | #                         | #                                         | #                 | #                                        | #           | nca.ecosystem.iucn:SeasonalFloodplainMarsh                 ,
  landcover:Wetland                                                                                      | #                          | #                               | #                                            | #               | #                                                                             | #                                     | true       | #                                                | #                                   | im:High               | #                         | #                         | hydrology:Episodic  | #                                | #                                                  | #                         | #                                         | #                 | #                                        | #           | nca.ecosystem.iucn:EpisodicAridFloodplain                  ,
  in (landcover:Shrubland, landcover:Grassland, landcover:BareArea, landcover:Wetland)                   | #                          | in (im:ModeratelyHigh, im:High) | #                                            | #               | in (ecology.incubation:VeryCold, ecology.incubation:Cold)                     | in (im:Low, im:Moderate)              | #          | in (im:None, ecology:VerySparse)                 | im:Low                              | #                     | im:High                   | #                         | #                   | #                                | in (im:VeryLow, im:Moderate, im:High, im:VeryHigh) | in (im:High, im:VeryHigh) | #                                         | #                 | #                                        | false       | nca.ecosystem.iucn:BorealTemperateMontanePeatBog           ,
  in (landcover:Shrubland, landcover:Grassland, landcover:BareArea, landcover:Wetland)                   | #                          | in (im:ModeratelyHigh, im:High) | #                                            | #               | in (ecology.incubation:VeryCold, ecology.incubation:Cold)                     | im:High                               | #          | in (im:None, ecology:VerySparse, ecology:Sparse) | im:High                             | #                     | in (im:High, im:Moderate) | #                         | #                   | #                                | #                                                  | #                         | #                                         | #                 | #                                        | #           | nca.ecosystem.iucn:BorealTemperateFen                     
}};

//--- BIOME TF1 - PalustrineWetland annotation---
model nca.ecosystem.iucn:PalustrineWetland type of nca.ecosystem.iucn:Ecosystem named biome_tf1_palustrine_wetland
	observing
		landcover:LandCoverType named landcover,
		level of im:Yearly earth:PrecipitationVolume named annual_precipitation_total,
		level of (im:Yearly hydrology:WaterVolume caused by hydrology:WaterBalance) named annual_water_budget_total,
		level of im:Mean im:Changed primitive_characteristic.climate:SeasonalAmplitude earth:AtmosphericTemperature named seasonal_diurnal_air_temperature_variability,
		type of ecology:MountainClimaticBeltZone named thermal_belts,
		level of im:Mean earth:AtmosphericTemperature during earth:Winter named winter_diurnal_air_temperature_mean,
		level of ecology:NetPrimaryProduction named annual_net_primary_productivity_total,
		presence of hydrology:Floodplain named floodplain,
		level of ecology:WoodyVegetation ecology:CanopyCover named tree_density,
		level of (chemistry:Basic chemistry:ExchangeCapacity of chemistry:Cation) named chemical_properties_base_saturation,
		level of (proportion of chemistry:Nitrogen in soil:Soil) named chemical_properties_n,
		level of (im:Depth of landcover:PeatBog earth:Region) named peat_thickness,
		type of hydrology:WaterBody named waterbody_type,
		type of hydrology:WaterPermanence named water_permanence,
		level of ecology:CanopyCover named canopy_cover,
		level of (im:Mean im:Height of ecology:Canopy) named canopy_height,
		level of ecology:LeafAreaIndex named leaf_area_index,
		level of (physical.incubation:Shadow im:Area of biology:Leaf) named leaf_size,
		type of ecology:LeafPhenology named phenology,
		level of (ratio of im:Area to earth:Dry im:Mass of biology:Leaf) named specific_leaf_area,
		presence of earth:Region with im:High im:Frequency of chemistry:Fire named periodicity
	lookup (landcover, annual_precipitation_total, annual_water_budget_total, seasonal_diurnal_air_temperature_variability, thermal_belts, winter_diurnal_air_temperature_mean, annual_net_primary_productivity_total, floodplain, tree_density, chemical_properties_base_saturation, chemical_properties_n, peat_thickness, waterbody_type, water_permanence, canopy_cover, canopy_height, leaf_area_index, leaf_size, phenology, specific_leaf_area, periodicity, ?)
	into BIOME_TF1_PALUSTRINE_WETLAND_ECOSYSTEM_TYPES;
 



























