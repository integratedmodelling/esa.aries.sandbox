//----------------------------------------------------------
//										   0 | im:VeryLow,
//									 1 to 25 | im:Low,
//									25 to 75 | im:Moderate,
//						  			    > 75 | im:High;

//annotation of landcover thresholds
//model level of ecology:Density
//observing percentage named landcover
//	lookup(landcover,?) into
//		landcover | category
//		-------------------------------
//				0 | ecology:Absent,
//		   0 to 1 | ecology:VerySparse,
//		  1 to 10 | ecology:Sparse,
//		 10 to 30 | ecology:Open,
//		      >70 | ecology:Dense;


//annotation of canopy_cover thresholds
model  'local:alessio.bulckaen:im.data.global:ecdc__vegetation__canopy_cover__viet_nam__2015'//'local:alessio.bulckaen:im.data.global:ecdc__vegetation__canopy_cover__greece__2015'
	as level of ecology:CanopyCover named canopy_cover
	lookup (self, ?) into
	 canopy_cover | category
	------------------------------
		 	   0  | im:None,		//ecology:Absent,
		 1 to 15  | im:Low,		//ecology:Sparse,
		15 to 65  | im:Moderate,	//ecology:Open,
	   65 to 100  | im:High;		//ecology:Dense;
 

//annotation of canopy_height thresholds
//model level of (im:Mean im:Height of ecology:Canopy)
//observing im:Mean im:Height of ecology:Canopy in m named canopy_height
//lookup (canopy_height) into
//	canopy_height | category
//	------------------------
//				0 | ecology:Absent,
//		   0 to 1 | im:VeryLow,
//		   1 to 5 | im:Low,
//		  5 to 20 | im:Moderate,
//		 20 to 40 | im:High,
//			 > 40 | im:VeryHigh;

//annotation of specific_leaf_area thresholds
model level of (ratio of  im:Area to im:Mass of biology:Leaf)
observing ratio of  im:Area to im:Mass of biology:Leaf in m^2/kg named specific_leaf_area
	lookup(specific_leaf_area) into
	specific_leaf_area | category
	--------------------------------
					<3 | im:VeryLow,
				3 to 5 | im:Low,
				5 to 8 | im:Moderate,
					>8 | im:VeryHigh;

//annotation of leaf_size thresholds
model level of (im:Area of biology:Leaf)
observing im:Area of biology:Leaf in mm^2 named leaf_size
	lookup(leaf_size) into
		leaf_size | category
		-----------------------
				<0| im:VeryLow,
		   0 to 3 | im:Low,
		   3 to 5 | im:Moderate,
		   5 to 8 | im:High,
			   >8 | im:VeryHigh;


//annotation of leaf_area_index thresholds
model level of ecology:LeafAreaIndex
observing ecology:LeafAreaIndex named leaf_area_index
lookup (leaf_area_index) into
	leaf_area_index | category
	-------------------------------------
			0 to 25 | ecology:Leptophyll,
		  25 to 225 | ecology:Nanophyll,
		225 to 2025 | ecology:Microphyll,
	   2025 to 4500 | ecology:Notophyll,
	  4500 to 18225 | ecology:Mesophyll,
	18225 to 164025 | ecology:Macrophyll,
		   > 164025 | ecology:Megaphyll; 



//annotation of fire_recurrence thresholds
//model level of (im:Yearly im:Occurrence of chemistry:Fire)
//observing count of im:Yearly im:Occurrence of chemistry:Fire in year named fire_recurrence
//lookup(fire_recurrence,?) into
//	fire_recurrence | category
//	-------------------------------
//				  1 | Annual,
//			 2 to 9 | Frequent,
//			0 to 19 | Occasional,
//			0 to 99 | Infrequent,
//			   >100 | Centennial;

//model presence of ecology:Tree
//observing
//	percentage of ecology:Forest ecology:CanopyCover named tree_density
//	set to [self == nodata ? false : true];
//model local:alessio.bulckaen:im.data.global:im-data-global-ecology.global_globmapftc_fractional_tree_cover_epsg4326_250m_2020
//as 	presence of ecology:Tree
//set to [self == unknown ? false : true];

model level of ecology:WoodyVegetation ecology:CanopyCover
observing
	percentage of ecology:Forest ecology:CanopyCover named tree_density,
	presence of ecology:Tree named tree_cover
	lookup(tree_density,tree_cover,?) into
	tree_density | tree_cover | category
	------------------------------
	 	 # 	 	 | 	 false    | ecology:Absent,
	   1 to 10 	 | 	 true	  | ecology:VerySparse,
	  10 to 40 	 |   true	  | ecology:Sparse;  
	  
//annotation of summer_diurnal_air_temperature_mean thresholds
model 'local:alessio.bulckaen:im.data.global:ecdc__climate__summer_diurnal_air_temperature_mean__global__1981_2010'
 as level of im:Mean earth:AtmosphericTemperature during earth:Summer named summer_diurnal_air_temperature_mean
	lookup(summer_diurnal_air_temperature_mean) into
	summer_diurnal_air_temperature_mean | category
	----------------------------------------------
	-10 to 0  | ecology.incubation:Cold,
	  0 to 10 | ecology.incubation:Cool,
	 10 to 18 | ecology.incubation:Mild,
	 18 to 22 | ecology.incubation:Warm,
	 22 to 28 | ecology.incubation:Hot,
	 28 to 35 | ecology.incubation:VeryHot,
	   >=35   | ecology.incubation:ExtremelyHot;             		