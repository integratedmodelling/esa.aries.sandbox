local:alessio.bulckaen:im.data.global:ecdc__vegetation__leaf_area_index__global__2018
as ecology:LeafAreaIndex named leaf_area_index
	lookup (self,?) into
	leaf_area_index|category
	-----------------------------
				<0| im:VeryLow,
		   0 to 3 | im:Low,
		   3 to 5 | im:Moderate,
		   5 to 8 | im:High,
			   >8 | im:VeryHigh;
