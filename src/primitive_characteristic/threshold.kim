project private namespace primitive_characteristic.threshold
using primitive_characteristic;

//TODO:Add proper concepts
identity Variability;

attribute Absent;

class Temperature
	has children
	ExtremelyCold,
	VeryCold,
	Cold,
	Cool,
	Mild,
	Warm,
	Hot,
	VeryHot,
	ExtremelyHot;

attribute FireFrequency
    "The characteristic interval of fire recurrence within a specific ecosystem, often referred to as the Fire Return Interval (FRI)."
    has children
        (Annual
            "Fire occurs every year; typical of tropical savannas or systems with high-biomass annual grasses."
        ),
        (Frequent
            "Sub-decadal recurrence (1–10 years). Characterized by fires occurring several times within a decade."
        ),
        (Occasional
            "Decadal recurrence (10–30 years). Fire occurs roughly once per decade or slightly less frequently."
        ),
        (Infrequent
            "Multi-decadal recurrence (30–100 years). Fire cycles span several decades, often allowing for significant woody fuel accumulation."
        ),
        (Centennial
            "Very low frequency (>100 years). Fire is a rare event, often occurring only under extreme climatic conditions, typical of some temperate rainforests or subalpine zones."
        )
; 

@colormap(values = { 
    Planar:      (46 139 87),    // Sea Green (Lowlands/Basins)ecology:Planar
    Foothill:    (154 205 50),   // Yellow Green (Transition)  ecology:Foothill
    Submontane:  (205 133 63),   // Peru/Light Brown (Uplands) ecology:Submontane
    Montane:     (139 69 19)     // Saddle Brown (Mountains)   ecology:Montane
})
abstract attribute ElevationZone
    "A classification of altitudinal zones based on the transition of vegetation and climate from lowlands to mountain peaks."
    has children
        (Planar
            "The lowest altitudinal zone, typically consisting of flat plains, coastal areas, or major river basins. Characterized by stable, warmer temperatures."
        ),
        (Foothill
            "Also known as the Piedmont or Colline zone; the transitional area between plains and mountains. Topography begins to show undulating hills."
        ),
        (Submontane
            "The lower slopes of a mountain range. This zone marks the transition where lowland species begin to drop out in favor of more cold-tolerant vegetation."
        ),
        (Montane
            "The main mountain forest belt. Characterized by cooler temperatures and distinct cloud or moisture patterns; typically situated below the subalpine zone."
        )
;

//@colormap(values = { 
//    chemistry:HighlyAcidic:   (255 0 0),     // Red
//    chemistry:Acidic:         (255 165 0),   // Orange
//    chemistry:Neutral:        (0 255 0),     // Green
//    chemistry:Alkaline:       (0 0 255),     // Blue
//    chemistry:HighlyAlkaline: (128 0 128)    // Purple
//})
quantity PHClassification
    "A logarithmic scale used to specify the acidity or basicity of an aqueous solution or soil medium."
    has children
        (HighlyAcidic
            "Solutions with a pH typically below 4.0. Often toxic to most aquatic life and plants due to heavy metal mobilization (e.g., Aluminum)."
        ),
        (Acidic
            "Solutions with a pH between 4.0 and 6.5. Common in peatlands and coniferous forests where organic acids are prevalent."
        ),
        (Neutral
            "Solutions with a pH approximately between 6.5 and 7.5. This is the optimal range for the majority of biological processes and nutrient uptake."
        ),
        (Alkaline
            "Also known as Basic; solutions with a pH between 7.5 and 9.0. Often found in limestone-rich (calcareous) soils."
        ),
        (HighlyAlkaline
            "Solutions with a pH above 9.0. Characterized by high concentrations of carbonates and typical of soda lakes or saline-alkali deserts."
        )
;

observe earth:Region named greece_test_area_2024
over space(shape=
"EPSG:4326 POLYGON ((20.679138515160957 38.18374883460746, 20.672359298475584 38.15695481086746, 20.65305372270607 38.13423222059453, 20.624160886757842 38.11904552707, 20.590079462989802 38.11371192003023, 20.55599803922176 38.11904552707, 20.527105203273532 38.13423222059453, 20.507799627504017 38.15695481086746, 20.501020410818647 38.18374883460746, 20.507799627504017 38.21053300753712, 20.527105203273532 38.23323181585647, 20.55599803922176 38.24839472743662, 20.590079462989802 38.25371848367516, 20.624160886757842 38.24839472743662, 20.65305372270607 38.23323181585647, 20.672359298475584 38.21053300753712, 20.679138515160957 38.18374883460746))",
		   grid="300 m"),
time(start=2015, end=2016, step=1.year);

/*
 * If any doubt check original classification here:
 * https://docs.google.com/spreadsheets/d/1ouf-TNAxZEIoh7GC6J66jW6pGSpLavgqAXGJgK1d9Kc/edit?gid=16843137#gid=16843137 
 */
observe /* a:urn:to:use#objectid as */ earth:Region named test_ecdc_greece
    over space(shape='EPSG:4326 POLYGON ((22.357147225076126 38.493707792574895, 22.157272360484562 38.493707792574895, 22.157272360484562 38.56620374670959, 22.357147225076126 38.56620374670959, 22.357147225076126 38.493707792574895))',
    		grid="100 m",
    		projection="EPSG:4326"),
    time(year=2020); 
   
number 'local:alessio.bulckaen:im.data.global:ecdc__surfacewater__hydroform__global__1984_2017' as hydroform_type;
//number 'local:alessio.bulckaen:im.data.global:ecdc__surfacewater__hydroform_meander__global__2004_2013'
//	as presence of hydrology.incubation:RiverMeander named hydroform_meander
//	set to [(self == 2 || self ==3 ? true : false)];   

model type of hydrology:WaterBody
observing 
	hydroform_type,
	presence of hydrology.incubation:RiverMeander named hydroform_meander
		lookup(hydroform_type, hydroform_meander) into
		hydroform_type 	|hydroform_meander| category
		--------------------------------------------
			 1			|	#	| hydrology:Watercourse,
		in ( 2 3)		|	#	| hydrology:InlandWaterBody,
			#			|  true	| hydrology:Meander
over space(shape="POLYGON ((180 -60, 180 80, -180 80, -180 -60, 180 -60))");
	
number 'local:alessio.bulckaen:im.data.global:ecdc__surfacewater__occurrence_regime_seasonality__global__1984_2021' as seasonal_water_regime;
number 'local:alessio.bulckaen:im.data.global:ecdc__surfacewater__occurrence_regime_ephemeral__global__1984_2021' as ephemeral_water_regime;
number 'local:alessio.bulckaen:im.data.global:ecdc__surfacewater__occurrence_regime_episodic__global__1984_2021'as episodic_water_regime;

model type of hydrology:WaterPermanence
observing
	seasonal_water_regime,
	ephemeral_water_regime,
	episodic_water_regime
	lookup(seasonal_water_regime, ephemeral_water_regime,episodic_water_regime, ?) into
		seasonal_water_regime|ephemeral_water_regime|episodic_water_regime|category
		---------------------------------------------------------------------------------------
			     1		     |			#			| 		#			  |hydrology:Permanent,
			     2		     |			#			| 		#			  |hydrology:Seasonal,
	     		 #		     |			#			| 		1			  |hydrology:Ephemeral,			     			 
		     	 #		     |		in (1 2)		| 		#			  |hydrology:Episodic;

model 'local:alessio.bulckaen:im.data.global:ecdc__surfacewater__watershed_hierarchy__global__2004_2013'
//as level of (hydrology:StreamOrder of hydrology:Watershed) classified into
as level of hydrology:StreamOrder classified into
	im:Low if in (1 to 3),
	im:Moderate if in (4 to 8),
	im:High if > 8;

number 'local:alessio.bulckaen:im.data.global:ecdc__surfacewater__watershed_hierarchy__global__2004_2013' as test_watershed_hierarchy;

//model 'local:alessio.bulckaen:im.data.global:ecdc__surfacewater__watershed_hierarchy__global__2004_2013'
////as level of (hydrology:StreamOrder of hydrology:Watershed) classified into
//as level of hydrology:StreamOrder classified into
//	im:Low if in (1 to 3),
//	im:Moderate if in (4 to 8),
//	im:High if > 8
////
////lookup(watershed_hierarchy) into
////watershed_hierarchy| category
////------------------------------
////			1 to 4 | im:Low,
////			4 to 9 | im:Moderate,
////			  >9   | im:High
//over space(shape="POLYGON ((-180 -55.87, -180 84.01, 180 84.01, 180 -55.87, -180 -55.87))");

@intensive(space)                        
model level of (im:Minimum im:Area of earth:WaterBody) named hydroform_morphology_area
observing im:Minimum im:Area of earth:WaterBody in km^2
		lookup (hydroform_morphology_area) into
		hydroform_morphology_area | category
		------------------------------------
							< 100 | im:Low,
	                        > 100 | im:High; 
 
//model level of (hydrology:StreamOrder of hydrology:Watershed) named watershed_hierarchy
//observing hydrology:StreamOrder of hydrology:Watershed	
//	 	lookup (watershed_hierarchy) into
//	 	watershed_hierarchy | category
//		----------------------------------
//					 1 to 4 | im:Low,
//	                 4 to 9 | im:Moderate,
//	                    > 9 | im:High;
@intensive(space)
model level of ecology:NetPrimaryProduction
observing ecology:NetPrimaryProduction in g/m^2 named annual_total_net_primary_productivity //g/m^2/day named npp
		lookup (annual_total_net_primary_productivity) into
        annual_total_net_primary_productivity | category
		----------------------------------------------------
										< 500 | im:Low,
				                  500 to 2000 | im:Moderate,
				                       > 2000 | im:High;

model 'local:alessio.bulckaen:im.data.global:ecdc__soil__fertility__global__2001_2020'
//	as level of soil.incubation:Fertility
//		lookup (fertility) into  into
//		fertility | category
//	    -------------------------
//		   0 to 3 | im:None,
//		   3 to 5 | im:Low,
//	       5 to 8 | im:Moderate,
//	      8 to 11 | im:High;
	as level of soil.incubation:Fertility named soil_fertility
	classified into
		im:None if in (0 1 2),
		im:Low if in (3 4),
		im:Moderate if in (5 6 7),
		im:High if in (8 9 10);

@intensive(space)
model level of (im:Depth of landcover:PeatBog earth:Region)
observing im:Depth of landcover:PeatBog earth:Region in cm named depth_peat_bog//g/m^2/day named npp
		lookup (depth_peat_bog) into
        depth_peat_bog | category
		-------------------------
   				   0   | Absent,
   			 0 to  0.3 | im:Low,
              0.3 to 1 | im:Moderate,
                   > 1 | im:High;

