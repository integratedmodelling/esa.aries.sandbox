//model presence of ecology:Tree
//observing
//	percentage of ecology:Forest ecology:CanopyCover named tree_density
//	set to [self == nodata ? false : true];
//model local:alessio.bulckaen:im.data.global:im-data-global-ecology.global_globmapftc_fractional_tree_cover_epsg4326_250m_2020
//as 	presence of ecology:Tree
//set to [self == unknown ? false : true];

model level of ecology:WoodyVegetation ecology:CanopyCover
observing
	percentage of ecology:Forest ecology:CanopyCover named tree_density,
	presence of ecology:Tree named tree_cover
	lookup(tree_density,tree_cover,?) into
	tree_density | tree_cover | category
	------------------------------
	 	 # 	 	 | 	 false    | ecology:Absent,
	   1 to 10 	 | 	 true	  | ecology:VerySparse,
	  10 to 40 	 |   true	  | ecology:Sparse;  


//annotation of leaf_size thresholds
model level of (im:Area of biology:Leaf) named leaf_size_typology
observing
	im:Area of biology:Leaf named leaf_size
	lookup (leaf_size,?) into
		  leaf_size | category
	-------------------------------------
	    0 to 25 	| ecology:Leptophyll,
	   25 to 225    | ecology:Nanophyll,
	  225 to 2025   | ecology:Microphyll,
	 2025 to 4500   | ecology:Notophyll,
	 4500 to 18225  | ecology:Mesophyll,
	18225 to 164025 | ecology:Macrophyll,
		  >= 164025 | ecology:Megaphyll; 
//over space(shape='POLYGON ((180 -90, 180 90, -180 90, -180 -90, 180 -90))');

model 'local:alessio.bulckaen:im.data.global:ecdc__wildfiredisturbances__recurrence__global__2002_2024'
	as level of (count of im:Yearly im:Occurrence of chemistry:Fire) named recurrence
	lookup (self, ?) into
		recurrence 	| category
		---------------------
		1			| ecology.incubation:Annual, // cate added this manually because it made sense in her head
		2 to 9 		| ecology.incubation:SubDecadal,
		10 to 19 	| ecology.incubation:Decadal,
		20 to 99 	| ecology.incubation:MultiDecadal,
		>100 		| ecology.incubation:Centennial;
//over space(shape='POLYGON ((180 -60.0003350977, 180 69.9999999937, -180 69.9999999937, -180 -60.0003350977, 180 -60.0003350977))');




/*
 * # Annotations moved from namespace: test_stac_resources ----------------------------------------------------------------------------------------
 */
model level of im:Daily im:Mean im:Yearly earth:AtmosphericTemperature named annual_diurnal_mean_air_temperature_level
	observing
		im:Daily im:Mean im:Yearly earth:AtmosphericTemperature in Celsius named annual_diurnal_mean_air_temperature
	lookup(annual_diurnal_mean_air_temperature, ?) into
		  annual_diurnal_mean_air_temperature | category
		---------------------------------------------------------------------------
					 < -25					  | ecology.incubation:ExtremelyCold ,
		 		-25 to -10					  | ecology.incubation:VeryCold		 ,
		 		-10 to 0					  | ecology.incubation:Cold			 ,
				  0 to 10					  | ecology.incubation:Cool			 ,
				 10 to 18					  | ecology.incubation:Mild			 ,
				 18 to 22					  | ecology.incubation:Warm			 ,
				 22 to 28					  | ecology.incubation:Hot			 ,
				 28 to 35					  | ecology.incubation:VeryHot		 ,
					 > 35					  | ecology.incubation:ExtremelyHot  ;

model local:alessio.bulckaen:im.data.global:ecdc__climate__annual_precipitation_total__global__1981_2010 
	as level of im:Yearly earth:PrecipitationVolume named annual_precipitation_total_level
		lookup(self, ?) into
		annual_precipitation_total	| category
		---------------------------------------------
					     < 200		| im:VeryLow  ,
					200 to 300		| im:Low	  ,
					300 to 900		| im:Moderate ,
					900 to 2000		| im:High	  ,
				         > 2000		| im:VeryHigh ;

model local:alessio.bulckaen:im.data.global:ecdc__climate__annual_water_budget_total__global__1981_2010 
	as level of (im:Yearly hydrology:WaterVolume caused by hydrology:WaterBalance) named annual_total_water_budget_level
	lookup(self, ?) into
		  annual_water_budget_total | category
		-------------------------------------------------
				< -500				| im:Low			,
		  -499 to -1				| im:ModeratelyLow  ,
			 1 to 499				| im:ModeratelyHigh ,
				> 500				| im:High			;
				
model local:alessio.bulckaen:im.data.global:ecdc__climate__winter_water_budget_total__global__1980_2010 
	as level of (hydrology:WaterVolume caused by hydrology:WaterBalance during earth:Winter) named winter_total_water_budget_level
	lookup(self, ?) into
		  winter_water_budget_total | category
		--------------------------------------------------
					  < -500		| im:Low			,
		 		-499 to -1			| im:ModeratelyLow	,
				   1 to 499			| im:ModeratelyHigh ,
					  > 500			| im:High			;

model local:alessio.bulckaen:im.data.global:ecdc__bioticassemblages__biotic_assemblage_pinniped_colonies__global__2022
	as presence of GBIF.SPECIES:4941589 ecology:Population named biotic_assemblage_pinniped_colonies_presence
	set to [((self == 1) || (self == 2)) ? true : false];

