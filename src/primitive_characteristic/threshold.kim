//					<3 | im:VeryLow,
//				3 to 5 | im:Low,
//				5 to 8 | im:Moderate,
//					>8 | im:VeryHigh;

//annotation of specific_leaf_area thresholds
model 'local:alessio.bulckaen:im.data.global:ecdc__vegetation__specific_leaf_area__global__2000_2020'
 as level of (ratio of  im:Area to im:Mass of biology:Leaf) named specific_leaf_area
lookup(specific_leaf_area) into
specific_leaf_area | category
-----------------------------
				<3 | im:Low,
			3 to 5 | im:ModeratelyLow,
			5 to 8 | im:ModeratelyHigh,
				>8 | im:High
over space(shape='POLYGON ((180 -60, 180 80, -180 80, -180 -60, 180 -60))');

