model local:alessio.bulckaen:im.data.global:ecdc__vegetation__canopy_cover__greece__2015
	as level of ecology:CanopyCover named canopy_cover_level_greece
	lookup (self, ?) into
	 canopy_cover | category
	------------------------------
		 	   0  | ecology:Absent,		
		 1 to 15  | ecology:Sparse,		
		15 to 65  | ecology:Open,	
	   65 to 100  | ecology:Dense;	
	   
model local:alessio.bulckaen:im.data.global:ecdc__vegetation__canopy_cover__norway__2015
	as level of ecology:CanopyCover named canopy_cover_level_norway
	lookup (self, ?) into
	 canopy_cover | category
	------------------------------
		 	   0  | ecology:Absent,		
		 1 to 15  | ecology:Sparse,		
		15 to 65  | ecology:Open,	
	   65 to 100  | ecology:Dense;
	   
model local:alessio.bulckaen:im.data.global:ecdc__vegetation__canopy_cover__south_africa__2015
	as level of ecology:CanopyCover named canopy_cover_level_south_africa
	lookup (self, ?) into
	 canopy_cover | category
	------------------------------
		 	   0  | ecology:Absent,		
		 1 to 15  | ecology:Sparse,		
		15 to 65  | ecology:Open,	
	   65 to 100  | ecology:Dense;
	   
