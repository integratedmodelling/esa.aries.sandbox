//annotation of canopy_height thresholds
model local:alessio.bulckaen:im.data.global:ecdc__vegetation__canopy_height__greece__2020
as level of (im:Mean im:Height of ecology:Canopy)
//observing im:Mean im:Height of ecology:Canopy in m named canopy_height
	lookup (self) into
	canopy_height | category
	------------------------
				0 | ecology:Absent,
		   0 to 1 | im:VeryLow,
		   1 to 5 | im:Low,
		  5 to 20 | im:Moderate,
		 20 to 40 | im:High,
			 > 40 | im:VeryHigh;
//over space(shape='POLYGON ((180 -90, 180 90, -180 90, -180 -90, 180 -90))');

////annotation of specific_leaf_area thresholds
//model level of (ratio of  im:Area to im:Mass of biology:Leaf)
