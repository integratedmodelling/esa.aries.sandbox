private namespace primitive_characteristic.climate;

/*
 * # 1) Summer diurnal mean air temperature.
 */
model local:alessio.bulckaen:im.data.global:ecdc__climate__summer_diurnal_air_temperature_mean__global__1981_2010 
	as im:Mean earth:AtmosphericTemperature during earth:Summer in Celsius named summer_diurnal_air_temperature_mean_input
	set to [self / 100];

model level of im:Mean earth:AtmosphericTemperature during earth:Summer named summer_diurnal_air_temperature_mean
	observing
		im:Mean earth:AtmosphericTemperature during earth:Summer in Celsius named summer_diurnal_air_temperature_mean_input
	lookup(summer_diurnal_air_temperature_mean_input, ?) into
		  summer_diurnal_air_temperature_mean	| category
		-----------------------------------------------------------------------------
				   -10 to 0						| ecology.incubation:Cold		  ,
					 0 to 10					| ecology.incubation:Cool		  ,
					10 to 18					| ecology.incubation:Mild		  ,
					18 to 22					| ecology.incubation:Warm		  ,
					22 to 28					| ecology.incubation:Hot		  ,
					28 to 35					| ecology.incubation:VeryHot	  ,
					    > 35					| ecology.incubation:ExtremelyHot ;
					    
/*
 * # 2) Winter diurnal mean air temperature.
 */
model local:alessio.bulckaen:im.data.global:ecdc__climate__winter_diurnal_air_temperature_mean__global__1981_2010 
	as im:Mean earth:AtmosphericTemperature during earth:Winter in Celsius named winter_diurnal_air_temperature_mean_input
	set to [self / 100];
	
model level of im:Mean earth:AtmosphericTemperature during earth:Winter named winter_diurnal_air_temperature_mean
	observing
		im:Mean earth:AtmosphericTemperature during earth:Winter in Celsius named winter_diurnal_air_temperature_mean_input
	lookup(winter_diurnal_air_temperature_mean_input, ?) into
		  winter_diurnal_air_temperature_mean	| category
		------------------------------------------------------------------------------
				 		< -25					| ecology.incubation:ExtremelyCold	,
				   -25 to -10					| ecology.incubation:VeryCold		,
				   -10 to 0						| ecology.incubation:Cold		  	,
					 0 to 10					| ecology.incubation:Cool		  	,
					10 to 18					| ecology.incubation:Mild		  	,
					18 to 22					| ecology.incubation:Warm	  		,
					22 to 28					| ecology.incubation:Hot 			;
					
/*
 * # 3) Potential tree growth.
 */
model local:alessio.bulckaen:im.data.global:ecdc__climate__potential_tree_growth__global__1981_2010
	as presence of im:Potential ecology:Tree caused by biology:Growth named potential_tree_growth
	set to [self == 1 ? true : false];
	
/*
 * # 4) Seasonal diurnal air temperature amplitude.
 */
model local:alessio.bulckaen:im.data.global:ecdc__climate__seasonal_diurnal_air_temperature_amplitude__global__1981_2010
	as im:Daily im:Differential im:Seasonal earth:AtmosphericTemperature in Celsius named seasonal_diurnal_air_temperature_amplitude_input;
	 
model level of im:Daily im:Differential im:Seasonal earth:AtmosphericTemperature named seasonal_diurnal_air_temperature_amplitude
	observing
		im:Daily im:Differential im:Seasonal earth:AtmosphericTemperature in Celsius named seasonal_diurnal_air_temperature_amplitude_input
	lookup(seasonal_diurnal_air_temperature_amplitude_input, ?) into
		seasonal_diurnal_air_temperature_amplitude  | category
	   --------------------------------------------------------------
					0  to 10 						| im:Low		,
					10 to 21 						| im:Moderate	,
					   > 21 						| im:High		;
					   
/*
 * # 5) Seasonal diurnal air temperature variability.
 */
model local:alessio.bulckaen:im.data.global:ecdc__climate__seasonal_diurnal_air_temperature_variability__global__1981_2010
	as im:Daily im:Changed im:Seasonal earth:AtmosphericTemperature in Celsius named seasonal_diurnal_air_temperature_variability_input
	set to [self * 0.1 - 273.5];
	
model level of im:Daily im:Changed im:Seasonal earth:AtmosphericTemperature named seasonal_diurnal_air_temperature_variability
	observing
		im:Daily im:Changed im:Seasonal earth:AtmosphericTemperature in Celsius named seasonal_diurnal_air_temperature_variability_input
	lookup(seasonal_diurnal_air_temperature_variability_input, ?) into
		   seasonal_diurnal_air_temperature_variability | category
		----------------------------------------------------------------------
						  0								| im:VeryLow		,
					 0 to 1								| im:ModeratelyLow	,						  
					 1 to 25							| im:Low			,
					25 to 75							| im:Moderate		,
						> 75							| im:High			;
						
/*
 * # 6) Annual total precipitation. (Note: unit of precipitation: 1 mm = 1 L/m^2 = 1 kg/m^2)
 */
@intensive(space,time)
model local:alessio.bulckaen:im.data.global:ecdc__climate__annual_precipitation_total__global__1981_2010
	as im:Yearly earth:PrecipitationVolume in mm/year named annual_precipitation_total_input;
	
model level of im:Yearly earth:PrecipitationVolume named annual_precipitation_total
	observing
		@intensive(space,time) im:Yearly earth:PrecipitationVolume in mm/year named annual_precipitation_total_input
		lookup(annual_precipitation_total_input, ?) into
		annual_precipitation_total	| category
		---------------------------------------------
					     < 200		| im:VeryLow  ,
					200 to 300		| im:Low	  ,
					300 to 900		| im:Moderate ,
					900 to 2000		| im:High	  ,
				         > 2000		| im:VeryHigh ;
				          
/*
 * # 7) Annual diurnal mean air temperature.
 */
model local:alessio.bulckaen:im.data.global:ecdc__climate__annual_diurnal_air_temperature_mean__global__1981_2010 
	as im:Daily im:Mean earth:AtmosphericTemperature during im:Year in Celsius named annual_diurnal_air_temperature_mean_input
	set to [self / 100];
	
model level of im:Daily im:Mean earth:AtmosphericTemperature during im:Year named annual_diurnal_air_temperature_mean
	observing
		im:Daily im:Mean earth:AtmosphericTemperature during im:Year in Celsius named annual_diurnal_air_temperature_mean_input
	lookup(annual_diurnal_air_temperature_mean_input, ?) into
		  annual_diurnal_air_temperature_mean | category
		---------------------------------------------------------------------------
					 < -25					  | ecology.incubation:ExtremelyCold ,
		 		-25 to -10					  | ecology.incubation:VeryCold		 ,
		 		-10 to 0					  | ecology.incubation:Cold			 ,
				  0 to 10					  | ecology.incubation:Cool			 ,
				 10 to 18					  | ecology.incubation:Mild			 ,
				 18 to 22					  | ecology.incubation:Warm			 ,
				 22 to 28					  | ecology.incubation:Hot			 ,
				 28 to 35					  | ecology.incubation:VeryHot		 ,
					 > 35					  | ecology.incubation:ExtremelyHot  ;
					  
/*
 * # 8) Annual total water budget. (Note: unit of water budget: 1 mm = 1 L/m^2 = 1 kg/m^2)
 */
@intensive(space,time)
model local:alessio.bulckaen:im.data.global:ecdc__climate__annual_water_budget_total__global__1981_2010
	as im:Yearly hydrology:WaterVolume caused by hydrology:WaterBalance in mm/year named annual_water_budget_total_input;
	
model level of (im:Yearly hydrology:WaterVolume caused by hydrology:WaterBalance) named annual_water_budget_total
	observing
		@intensive(space,time) im:Yearly hydrology:WaterVolume caused by hydrology:WaterBalance in mm/year named annual_water_budget_total_input
	lookup(annual_water_budget_total_input, ?) into
		  annual_water_budget_total | category
		-------------------------------------------------
				< -500				| im:Low			,
		  -499 to -1				| im:ModeratelyLow  ,
			 1 to 499				| im:ModeratelyHigh ,
				> 500				| im:High			;
				
/*
 * # 9) Winter total water budget. (Note: unit of water budget: 1 mm = 1 L/m^2 = 1 kg/m^2)
 */
@intensive(space,time)
model local:alessio.bulckaen:im.data.global:ecdc__climate__winter_water_budget_total__global__1980_2010 
	as hydrology:WaterVolume caused by hydrology:WaterBalance during earth:Winter in mm/year named winter_water_budget_total_input;
	
model level of (hydrology:WaterVolume caused by hydrology:WaterBalance during earth:Winter) named winter_water_budget_total
	observing
		@intensive(space,time) hydrology:WaterVolume caused by hydrology:WaterBalance during earth:Winter in mm/year named winter_water_budget_total_input
	lookup(winter_water_budget_total_input, ?) into
		  winter_water_budget_total | category
		--------------------------------------------------
					  < -500		| im:Low			,
		 		-499 to -1			| im:ModeratelyLow	,
				   1 to 499			| im:ModeratelyHigh ,
					  > 500			| im:High			;
					   
/*
 * # 10) Thermal belts.
 */
model local:alessio.bulckaen:im.data.global:ecdc__climate__thermal_belts__global__1950_2000 
	as type of ecology:MountainClimaticBeltZone named thermal_belts
	classified into
		ecology:UpperAlpine  if 2,
		ecology:LowerAlpine  if 3,
		ecology:UpperMontane if 4,
		ecology:LowerMontane if 5,
		ecology:Lowland 	 if in (6, 7);
		