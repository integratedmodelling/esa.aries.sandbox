worldview im;

@test(
    name = "test_primitive_characteristc_anthropogenic",
    description  = "",
    // add to the list any concepts to be observed in the context below
    observations = (
 //UE   "primitive_characteristic.anthropogenic.mining_areas"
    "primitive_characteristic.anthropogenic.managed_waters_canal_greece"
    "primitive_characteristic.anthropogenic.managed_waters_reservoir_greece"
