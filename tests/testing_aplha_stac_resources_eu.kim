    over space(shape="EPSG:4326 POLYGON ((20.586364586796286 38.218040767163046, 20.60384282465619 38.2170599023822, 20.604675147641128 38.20365344311736, 20.586780727333995 38.203816948183686, 20.586364586796286 38.218040767163046))", grid="30 m"),
    time(year=2024)
;

