     over space (shape="EPSG:4326 POLYGON ((15.895100637423043 50.615879388723215, 15.455647512423042 50.615879388723215, 15.455647512423042 50.743145479474634, 15.895100637423043 50.743145479474634, 15.895100637423043 50.615879388723215))",    
